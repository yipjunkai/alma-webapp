# Backend configuration. Copy to backend/.env (or run `just setup`).
# Every value below has a working default — the app runs as-is.

DATABASE_URL=sqlite:///./data/alma.db

# Session signing key. Leave unset for local dev: a strong random key is
# generated per run (sessions won't survive a backend restart — just sign in
# again). REQUIRED in production: must be >=32 chars and not a placeholder.
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# SECRET_KEY=

# Attorney login for the internal UI.
ADMIN_EMAIL=attorney@example.com
ADMIN_PASSWORD=changeme

# Where new-lead notifications are sent.
ATTORNEY_EMAIL=attorney@example.com
EMAIL_FROM=Alma <onboarding@resend.dev>

# Used for CORS and the admin link in the attorney email.
FRONTEND_ORIGIN=http://localhost:3000

# Leave RESEND_API_KEY empty to log emails to the console instead of sending them.
RESEND_API_KEY=

UPLOAD_DIR=./data/uploads

# Logging: LOG_FORMAT=console (readable, default) or json (structured, for prod).
LOG_LEVEL=INFO
LOG_FORMAT=console
