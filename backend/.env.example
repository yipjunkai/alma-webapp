DATABASE_URL=sqlite:///./data/alma.db

# Session signing key. Leave unset for local dev: a strong random key is
# generated per run (sessions won't survive a backend restart — just sign in
# again). REQUIRED in production: must be >=32 chars and not a placeholder.
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# SECRET_KEY=

ADMIN_EMAIL=attorney@example.com
ADMIN_PASSWORD=changeme
ATTORNEY_EMAIL=attorney@example.com
EMAIL_FROM=Alma <onboarding@resend.dev>
FRONTEND_ORIGIN=http://localhost:3000

# Leave RESEND_API_KEY empty to log emails to the console instead of sending them.
RESEND_API_KEY=

UPLOAD_DIR=./data/uploads
